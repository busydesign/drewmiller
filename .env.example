# Local Postgres (docker compose up -d)
DATABASE_URL="postgresql://drew:drew@localhost:5432/drewmiller?schema=public"

ADMIN_EMAIL="admin@drewmiller.co.nz"
ADMIN_PASSWORD="changeme"
AUTH_SECRET="replace-with-a-long-random-string"

# Public site URL (Railway domain in staging, custom domain in prod)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Blog cover uploads (optional). On Railway mount a volume at /data/uploads
# and set this so files survive redeploys. Locally defaults to public/uploads.
# UPLOAD_DIR="/data/uploads"

# Meta (Facebook) Pixel — optional override; defaults to production pixel in code
# NEXT_PUBLIC_META_PIXEL_ID="1341330209700908"

# Google Analytics 4 — optional override; defaults to production measurement ID in code
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-TPY1WE8SBB"

# Form notifications → Drew (defaults to drew.miller@raywhite.com if unset)
NOTIFY_EMAIL="drew.miller@raywhite.com"
NOTIFY_NAME="Drew Miller"

# Email — use Resend OR SMTP (Resend wins if both are set)
# https://resend.com — verify your sending domain for production
RESEND_API_KEY=""
EMAIL_FROM="Drew Miller website <onboarding@resend.dev>"

# SMTP alternative (e.g. Google Workspace / App Password)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="you@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM="Drew Miller website <you@gmail.com>"

# Optional: Squarespace export path for full re-import
MIGRATION_EXPORT="../drewmiller-migration/export"
