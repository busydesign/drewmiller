# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local databases / dumps
*.db
*.db-journal
/prisma/dev.db*
/tmp/

# Local-only symlink to Squarespace image export
/public/migration-images

# Uploaded blog / admin media (keep folder via .gitkeep)
/public/uploads/**
!/public/uploads/
!/public/uploads/*/
!/public/uploads/**/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
